{
  "name": "auth-service",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "nodemon --exec tsx src/main.ts",
    "start": "tsx src/main.ts",
    "build": "tsc",
    "migrate": "npx prisma migrate dev --schema=./prisma/schema.prisma",
    "generate": "npx prisma generate --schema=./prisma/schema.prisma",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "nodemon": "^3.1.10",
    "prisma": "^6.18.0",
    "tsx": "^4.16.3",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@arcjet/inspect": "^1.0.0-beta.13",
    "@arcjet/node": "^1.0.0-beta.13",
    "@prisma/client": "^6.18.0",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.8.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "google-auth-library": "^10.5.0",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.2",
    "qrcode": "^1.5.4",
    "resend": "^6.5.2",
    "speakeasy": "^2.0.0"
  }
}
