// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String          @id @default(uuid())
  name                     String
  username                 String          @unique
  email                    String          @unique
  password                 String?
  dateOfBirth              DateTime?
  gender                   Gender?
  role                     UserRole        @default(STUDENT)
  profileImg               String?
  bio                      String?         @db.VarChar(200)
  country                  String?
  onboardingCompleted      Boolean         @default(false)
  goals                    String[]        @default([])
  newsletterEnabled        Boolean         @default(false)
  preferences              UserPreference?
  verified                 Boolean         @default(false)
  twoFactorEnabled         Boolean         @default(false)
  twoFactorSecret          String? // Encrypted TOTP secret
  twoFactorBackupCodes     String[]        @default([]) // Encrypted backup codes
  deviceBlocked            Boolean         @default(false) // Blocked due to new device
  pendingDeviceFingerprint String? // Device fingerprint waiting for verification
  isActive                 Boolean         @default(true) // Account active status
  deletedAt                DateTime? // Soft delete timestamp
  lastLoginAt              DateTime?
  lastUsernameChange       DateTime? // Track when username was last changed
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  providers              AuthProvider[]
  interests              UserInterest[]
  enrollments            CourseEnrollment[]
  devices                UserDevice[]
  sessions               Session[]
  sentParentRequests     ParentLinkRequest[] @relation("SentParentRequests")
  receivedParentRequests ParentLinkRequest[] @relation("ReceivedParentRequests")
  sentUnlinkRequests     UnlinkRequest[]     @relation("SentUnlinkRequests")
  receivedUnlinkRequests UnlinkRequest[]     @relation("ReceivedUnlinkRequests")
  parentLinks            ParentChildLink[]   @relation("ChildLinks")
  childLinks             ParentChildLink[]   @relation("ParentLinks")
  locationHistory        LocationHistory[]

  @@index([username])
  @@index([role])
  @@index([email])
}

model UserPreference {
  id              String   @id @default(uuid())
  userId          String   @unique
  language        String?  @default("system") // "system", "en", "ar" - if system language not ar/en, defaults to en
  themePreference String?  @default("system") // "system", "light", "dark"
  notifications   Boolean? @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserDevice {
  id                String    @id @default(uuid())
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            String
  deviceFingerprint String
  deviceName        String?
  ipAddress         String?
  userAgent         String?
  platform          Platform?
  isTrusted         Boolean   @default(false)
  lastLoginAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  sessions Session[]

  @@unique([userId, deviceFingerprint])
  @@index([userId])
  @@index([deviceFingerprint])
}

enum Platform {
  WEB
  ANDROID
  IOS
  DESKTOP
}

model AuthProvider {
  id           String   @id @default(uuid())
  provider     Provider
  providerId   String
  accessToken  String?
  refreshToken String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([provider, providerId])
  @@index([userId])
}

model Interest {
  id        String         @id @default(uuid())
  name      String         @unique
  users     UserInterest[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model UserInterest {
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  interest   Interest @relation(fields: [interestId], references: [id], onDelete: Cascade)
  interestId String
  createdAt  DateTime @default(now())

  @@id([userId, interestId])
  @@index([userId])
  @@index([interestId])
}

model CourseEnrollment {
  id         String   @id @default(uuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  courseId   String
  enrolledAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

model Session {
  id       String      @id @default(uuid())
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String
  device   UserDevice? @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  deviceId String?

  // Token identifiers
  sessionToken String  @unique // Main session identifier (can be JWT or opaque token)
  refreshToken String? @unique // Optional refresh token for JWT rotation

  // Session metadata
  ipAddress String? // Current IP from latest request
  userAgent String? // Current user agent from latest request
  location  String? // Geographic location (city/country)

  // GPS Location tracking (from mobile device headers)
  lastLatitude          Float?    // GPS latitude coordinate
  lastLongitude         Float?    // GPS longitude coordinate
  lastLocationAccuracy  Float?    // Accuracy in meters (lower = more precise)
  lastLocationAddress   String?   // Full reverse-geocoded address
  lastLocationTimestamp DateTime? // When location was last updated

  // Session state
  isActive  Boolean @default(true)
  isRevoked Boolean @default(false)

  // Expiration times
  expiresAt        DateTime // When this session expires
  refreshExpiresAt DateTime? // When refresh token expires (if using refresh tokens)

  // Activity tracking
  lastActivityAt DateTime  @default(now()) // Last time session was used
  createdAt      DateTime  @default(now())
  revokedAt      DateTime? // When session was revoked

  @@index([userId])
  @@index([deviceId])
  @@index([sessionToken])
  @@index([refreshToken])
  @@index([isActive, expiresAt]) // For finding active, non-expired sessions
  @@index([userId, isActive]) // For finding user's active sessions
  @@index([userId, isActive, isRevoked, expiresAt]) // OPTIMIZED: For auth middleware combined query
  @@index([expiresAt]) // OPTIMIZED: For expired session cleanup jobs
}

// Location history for child tracking feature
model LocationHistory {
  id        String   @id @default(uuid())
  userId    String
  latitude  Float
  longitude Float
  accuracy  Float?
  address   String?
  timestamp DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, timestamp])
  @@index([timestamp]) // OPTIMIZED: For time-range queries and cleanup jobs
}

enum UserRole {
  STUDENT
  TEACHER
  PARENT
  INSTRUCTOR
  ASSISTANT
  HR
  RECRUITER
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum Provider {
  EMAIL
  GOOGLE
  APPLE
}

model ParentLinkRequest {
  id          String        @id @default(uuid())
  childId     String // User requesting to link (child)
  parentId    String // Parent being requested
  status      RequestStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  respondedAt DateTime?

  child  User @relation("SentParentRequests", fields: [childId], references: [id], onDelete: Cascade)
  parent User @relation("ReceivedParentRequests", fields: [parentId], references: [id], onDelete: Cascade)

  @@unique([childId, parentId])
  @@index([childId])
  @@index([parentId])
  @@index([status])
}

model ParentChildLink {
  id        String   @id @default(uuid())
  parentId  String
  childId   String
  createdAt DateTime @default(now())

  parent User @relation("ParentLinks", fields: [parentId], references: [id], onDelete: Cascade)
  child  User @relation("ChildLinks", fields: [childId], references: [id], onDelete: Cascade)

  @@unique([parentId, childId])
  @@index([parentId])
  @@index([childId])
}

enum RequestStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
}

model UnlinkRequest {
  id          String        @id @default(uuid())
  childId     String // User requesting to unlink (child)
  parentId    String // Parent being requested to unlink from
  status      RequestStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  respondedAt DateTime?

  child  User @relation("SentUnlinkRequests", fields: [childId], references: [id], onDelete: Cascade)
  parent User @relation("ReceivedUnlinkRequests", fields: [parentId], references: [id], onDelete: Cascade)

  @@unique([childId, parentId])
  @@index([childId])
  @@index([parentId])
  @@index([status])
}

