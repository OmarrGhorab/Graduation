              "host": ["{{chat_base_url}}"],
              "path": ["conversations", "{{conversation_id}}", "members"]
            }
          }
        },
        {
          "name": "Remove Member",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
