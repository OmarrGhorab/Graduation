                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"{{student_user_id}}\"\n}"
            },
            "url": {
              "raw": "{{chat_base_url}}/conversations/{{conversation_id}}/members",
              "host": ["{{chat_base_url}}"],
              "path": ["conversations", "{{conversation_id}}", "members"]
            }
          }
        },
        {
          "name": "Update Member Role (Assign Admin/Assistant)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{teacher_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"{{student_user_id}}\",\n  \"role\": \"ADMIN\"\n}"
            },
            "url": {
              "raw": "{{chat_base_url}}/conversations/{{conversation_id}}/members/role",
              "host": ["{{chat_base_url}}"],
              "path": ["conversations", "{{conversation_id}}", "members", "role"]
            }
          }
        }
      ]
    },
    {
      "name": "4. Messages",
      "item": [
        {
          "name": "Send Text Message",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Message sent successfully', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.id).to.exist;",
                  "    pm.expect(jsonData.content).to.exist;",
                  "    pm.collectionVariables.set('message_id', jsonData.id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{teacher_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"text\",\n  \"content\": \"Hello everyone! This is a test message from Postman.\",\n  \"media_urls\": []\n}"
            },
            "url": {
              "raw": "{{chat_base_url}}/conversations/{{conversation_id}}/messages",
              "host": ["{{chat_base_url}}"],
              "path": ["conversations", "{{conversation_id}}", "messages"]
            }
          }
        },
        {
          "name": "Get Messages",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{teacher_token}}"
              }
            ],
            "url": {
              "raw": "{{chat_base_url}}/conversations/{{conversation_id}}/messages?limit=50&offset=0",
              "host": ["{{chat_base_url}}"],
              "path": ["conversations", "{{conversation_id}}", "messages"],
              "query": [
                {
                  "key": "limit",
                  "value": "50"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            }
          }
        },
        {
          "name": "Send Image Message",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{teacher_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"image\",\n  \"content\": \"Check out this image!\",\n  \"media_urls\": [\"https://res.cloudinary.com/demo/image/upload/sample.jpg\"]\n}"
            },
            "url": {
              "raw": "{{chat_base_url}}/conversations/{{conversation_id}}/messages",
              "host": ["{{chat_base_url}}"],
              "path": ["conversations", "{{conversation_id}}", "messages"]
            }
          }
        },
        {
          "name": "Pin Message",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{teacher_token}}"
              }
            ],
            "url": {
              "raw": "{{chat_base_url}}/conversations/{{conversation_id}}/messages/{{message_id}}/pin",
              "host": ["{{chat_base_url}}"],
              "path": ["conversations", "{{conversation_id}}", "messages", "{{message_id}}", "pin"]
            }
          }
        },
        {
          "name": "Get Pinned Messages",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{teacher_token}}"
              }
            ],
            "url": {
              "raw": "{{chat_base_url}}/conversations/{{conversation_id}}/messages/pinned",
              "host": ["{{chat_base_url}}"],
              "path": ["conversations", "{{conversation_id}}", "messages", "pinned"]
            }
          }
        },
        {
          "name": "Unpin Message",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{teacher_token}}"
              }
            ],
            "url": {
              "raw": "{{chat_base_url}}/conversations/{{conversation_id}}/messages/{{message_id}}/pin",
              "host": ["{{chat_base_url}}"],
              "path": ["conversations", "{{conversation_id}}", "messages", "{{message_id}}", "pin"]
            }
          }
        }
      ]
    },
