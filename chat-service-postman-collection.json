  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "Login Teacher",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response has access token', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.accessToken).to.exist;",
                  "    pm.collectionVariables.set('teacher_token', jsonData.accessToken);",
                  "    pm.collectionVariables.set('teacher_user_id', jsonData.user.id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"emailOrUsername\": \"{{teacher_email}}\",\n  \"password\": \"{{teacher_password}}\"\n}"
            },
            "url": {
              "raw": "{{auth_base_url}}/auth/login",
              "host": ["{{auth_base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Login Student",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response has access token', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.accessToken).to.exist;",
                  "    pm.collectionVariables.set('student_token', jsonData.accessToken);",
                  "    pm.collectionVariables.set('student_user_id', jsonData.user.id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"emailOrUsername\": \"{{student_email}}\",\n  \"password\": \"{{student_password}}\"\n}"
            },
            "url": {
              "raw": "{{auth_base_url}}/auth/login",
              "host": ["{{auth_base_url}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "2. Conversations",
      "item": [
        {
          "name": "Create Group Chat (Teacher)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Group created successfully', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.id).to.exist;",
                  "    pm.expect(jsonData.type).to.eql('GROUP');",
                  "    pm.collectionVariables.set('conversation_id', jsonData.id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{teacher_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Study Group\",\n  \"member_ids\": []\n}"
            },
            "url": {
              "raw": "{{chat_base_url}}/conversations",
              "host": ["{{chat_base_url}}"],
              "path": ["conversations"]
            }
          }
        },
        {
          "name": "Create Direct Chat",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Direct chat created', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.id).to.exist;",
                  "    pm.expect(jsonData.type).to.eql('DIRECT');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{teacher_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"peer_id\": \"{{student_user_id}}\"\n}"
            },
            "url": {
              "raw": "{{chat_base_url}}/conversations/direct",
              "host": ["{{chat_base_url}}"],
              "path": ["conversations", "direct"]
            }
          }
        },
        {
          "name": "Get User Conversations (Teacher)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{teacher_token}}"
              }
            ],
            "url": {
              "raw": "{{chat_base_url}}/conversations",
              "host": ["{{chat_base_url}}"],
              "path": ["conversations"]
            }
          }
        },
        {
          "name": "Get Single Conversation",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{teacher_token}}"
              }
            ],
            "url": {
              "raw": "{{chat_base_url}}/conversations/{{conversation_id}}",
              "host": ["{{chat_base_url}}"],
              "path": ["conversations", "{{conversation_id}}"]
            }
          }
        },
        {
          "name": "Delete Conversation (Owner Only)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{teacher_token}}"
              }
            ],
            "url": {
              "raw": "{{chat_base_url}}/conversations/{{conversation_id}}",
              "host": ["{{chat_base_url}}"],
              "path": ["conversations", "{{conversation_id}}"]
            }
          }
        },
        {
          "name": "Leave Conversation",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{student_token}}"
              }
            ],
            "url": {
              "raw": "{{chat_base_url}}/conversations/{{conversation_id}}/leave",
              "host": ["{{chat_base_url}}"],
              "path": ["conversations", "{{conversation_id}}", "leave"]
            }
          }
        }
      ]
    },
    {
      "name": "3. Member Management",
      "item": [
