# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/graduation_notification_db"

# Redis Configuration  
REDIS_URL="redis://localhost:6379"

# Internal Service Authentication
INTERNAL_SERVICE_SECRET="your-internal-service-secret-here"

# Server Configuration
PORT=6003
NODE_ENV=development

# JWT Configuration (must match auth-service JWT_ACCESS_SECRET)
JWT_ACCESS_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# CORS Configuration
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:8080,http://localhost:3001"
