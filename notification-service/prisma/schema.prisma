// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String   // Type of notification (e.g., "parent_link_request", "unlink_request_accepted")
  data      Json     // Additional notification data as JSON
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, read])
  @@index([createdAt])
}
