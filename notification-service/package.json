    "migrate": "npx prisma migrate dev --schema=./prisma/schema.prisma",
    "generate": "npx prisma generate --schema=./prisma/schema.prisma"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.0.0",
    "nodemon": "^3.1.10",
    "prisma": "^6.18.0",
    "tsx": "^4.16.3",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@prisma/client": "^6.18.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "firebase-admin": "^13.6.0",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.2"
  }
