{
	"info": {
		"_postman_id": "auth-service-collection",
		"name": "Auth Service - Notifications, Parent Link & Onboarding",
		"description": "Complete API collection for testing notifications, parent-link requests, and onboarding endpoints",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "Register User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    const jsonData = pm.response.json();",
									"    // Tokens are set in cookies automatically",
									"    pm.environment.set(\"user_id\", jsonData.user.id);",
									"    pm.environment.set(\"user_email\", jsonData.user.email);",
									"    pm.environment.set(\"otp\", jsonData.otp || \"\");",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"John Doe\",\n    \"username\": \"johndoe\",\n    \"email\": \"john@example.com\",\n    \"password\": \"password123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/auth/register",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"auth",
								"register"
							]
						}
					},
					"response": []
				},
				{
					"name": "Login User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const jsonData = pm.response.json();",
									"    pm.environment.set(\"user_id\", jsonData.user.id);",
									"    pm.environment.set(\"user_email\", jsonData.user.email);",
									"    // Tokens are in cookies",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"emailOrUsername\": \"john@example.com\",\n    \"password\": \"password123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/auth/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"auth",
								"login"
							]
						}
					},
					"response": []
				},
				{
					"name": "Register Parent User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    const jsonData = pm.response.json();",
									"    pm.environment.set(\"parent_id\", jsonData.user.id);",
									"    pm.environment.set(\"parent_email\", jsonData.user.email);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Parent User\",\n    \"username\": \"parentuser\",\n    \"email\": \"parent@example.com\",\n    \"password\": \"password123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/auth/register",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"auth",
								"register"
							]
						}
					},
					"response": []
				},
				{
					"name": "Refresh Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const jsonData = pm.response.json();",
									"    pm.environment.set(\"user_id\", jsonData.user.id);",
									"    // New tokens are set in cookies automatically",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/auth/refresh",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"auth",
								"refresh"
							]
						},
						"description": "Refresh access token using refresh token from cookies. Returns new access token and rotates refresh token for security. No authentication required (uses refresh token)."
					},
					"response": []
				},
				{
					"name": "Logout",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/auth/logout",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"auth",
								"logout"
							]
						},
						"description": "Logout user and revoke refresh token. Clears authentication cookies."
					},
					"response": []
				},
				{
					"name": "Resend Verification OTP",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const jsonData = pm.response.json();",
									"    if (jsonData.otp) {",
									"        pm.environment.set(\"verification_otp\", jsonData.otp);",
									"        console.log('Verification OTP:', jsonData.otp);",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"{{user_email}}\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/auth/resend-verification-otp",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"auth",
								"resend-verification-otp"
							]
						},
						"description": "Resend verification OTP to user's email. Use this if user didn't receive OTP during registration or OTP expired. Rate limited to prevent abuse."
					},
					"response": []
				},
				{
					"name": "Verify Email OTP",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    console.log('Email verified successfully');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"{{user_email}}\",\n    \"otp\": \"{{verification_otp}}\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/auth/verify-email-otp",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"auth",
								"verify-email-otp"
							]
						},
						"description": "Verify email with OTP received via email or from registration/resend response."
					},
					"response": []
				}
			]
		},
		{
			"name": "Notifications",
			"item": [
				{
					"name": "Register FCM Token",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"token\": \"FCM_DEVICE_TOKEN\",\n    \"platform\": \"ios\",\n    \"deviceId\": \"optional-device-id\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/notifications/register-token",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"notifications",
								"register-token"
							]
						},
						"description": "Register FCM token for push notifications. Mobile clients should call this after obtaining FCM token from Firebase."
					},
					"response": []
				},
				{
					"name": "Unregister FCM Token",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"token\": \"FCM_DEVICE_TOKEN\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/notifications/unregister-token",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"notifications",
								"unregister-token"
							]
						},
						"description": "Unregister FCM token. Mobile clients should call this on logout or when token becomes invalid."
					},
					"response": []
				},
				{
					"name": "Get Notifications (History)",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/notifications?page=1&limit=10&unreadOnly=false",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"notifications"
							],
							"query": [
								{
									"key": "page",
									"value": "1"
								},
								{
									"key": "limit",
									"value": "10"
								},
								{
									"key": "unreadOnly",
									"value": "false"
								}
							]
						},
						"description": "Get paginated notification history. Real-time notifications are delivered via FCM push notifications."
					},
					"response": []
				}
			]
		},
		{
			"name": "Parent Link",
			"item": [
				{
					"name": "Search Parents",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/parent-link/search?query=parent&page=1&limit=10",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"parent-link",
								"search"
							],
							"query": [
								{
									"key": "query",
									"value": "parent",
									"description": "Search by username, email, or name"
								},
								{
									"key": "page",
									"value": "1",
									"description": "Page number (default: 1)"
								},
								{
									"key": "limit",
									"value": "10",
									"description": "Results per page (default: 10, max: 50)"
								}
							]
						},
						"description": "Search for parents by username, email, or name. Only returns users with PARENT role."
					},
					"response": []
				},
				{
					"name": "Send Parent Link Request",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    const jsonData = pm.response.json();",
									"    pm.environment.set(\"request_id\", jsonData.request.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"parentId\": \"{{parent_id}}\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/parent-link/request",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"parent-link",
								"request"
							]
						},
						"description": "Send a parent link request from a child to a parent. This will trigger a notification to the parent."
					},
					"response": []
				},
				{
					"name": "Get Pending Requests (Child View)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/parent-link/requests",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"parent-link",
								"requests"
							]
						},
						"description": "Get pending requests. If user is a PARENT, returns requests received. If user is a CHILD, returns requests sent."
					},
					"response": []
				},
				{
					"name": "Get Pending Requests (Parent View)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/parent-link/requests",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"parent-link",
								"requests"
							]
						},
						"description": "Get pending requests received by parent. Parent sees child information."
					},
					"response": []
				},
				{
					"name": "Respond to Request (Accept)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    pm.environment.set(\"link_id\", pm.response.json().request.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"requestId\": \"{{request_id}}\",\n    \"action\": \"accept\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/parent-link/respond",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"parent-link",
								"respond"
							]
						},
						"description": "Accept a parent link request. Only parents can respond. Creates a parent-child link and sends notification to child."
					},
					"response": []
				},
				{
					"name": "Respond to Request (Decline)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"requestId\": \"{{request_id}}\",\n    \"action\": \"decline\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/parent-link/respond",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"parent-link",
								"respond"
							]
						},
						"description": "Decline a parent link request. Only parents can respond. Sends notification to child."
					},
					"response": []
				},
				{
					"name": "Get Linked Accounts (Child View)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/parent-link/linked",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"parent-link",
								"linked"
							]
						},
						"description": "Get linked parents for a child user, or linked children for a parent user."
					},
					"response": []
				},
				{
					"name": "Get Linked Accounts (Parent View)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/parent-link/linked",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"parent-link",
								"linked"
							]
						},
						"description": "Get linked children for a parent user."
					},
					"response": []
				}
			]
		},
